{
  "type": "object",
  "properties": {
    "attempts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "correction": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Corrected Japanese sentence when the attempt is not fully correct."
          },
          "englishCue": {
            "type": "string",
            "allOf": [
              {
                "minLength": 1,
                "description": "English prompt or cue that the user responded to."
              }
            ]
          },
          "patternTag": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Short grammar or expression tag for the practice item."
          },
          "reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Brief explanation of why the attempt received its result."
          },
          "result": {
            "type": "string",
            "enum": [
              "correct",
              "usable",
              "incorrect"
            ],
            "description": "Assessment result for the user attempt."
          },
          "userAttempt": {
            "type": "string",
            "allOf": [
              {
                "minLength": 1,
                "description": "Japanese sentence or response written by the user."
              }
            ]
          }
        },
        "required": [
          "englishCue",
          "result",
          "userAttempt"
        ],
        "additionalProperties": false
      },
      "allOf": [
        {
          "minItems": 1,
          "description": "Practice attempts to import."
        }
      ]
    }
  },
  "required": [
    "attempts"
  ],
  "additionalProperties": false,
  "title": "Practice import JSON",
  "description": "JSON payload for importing Japanese immersion practice attempts."
}
